# AI Content Generator - Environment Variables
# Скопируйте этот файл в .env и заполните своими значениями

# =============================================================================
# YOUTUBE DATA API v3
# =============================================================================
# Получить ключ: https://console.cloud.google.com/apis/credentials
YOUTUBE_API_KEY=your_youtube_api_key_here

# =============================================================================
# ABACUS AI API
# =============================================================================
# Ключ автоматически подтягивается из переменной окружения
ABACUS_API_KEY=your_abacus_api_key_here

# =============================================================================
# DATABASE (PostgreSQL)
# =============================================================================
DB_HOST=localhost
DB_PORT=5432
DB_NAME=video_automation
DB_USER=postgres
DB_PASSWORD=your_database_password_here

# =============================================================================
# ОПЦИОНАЛЬНЫЕ НАСТРОЙКИ
# =============================================================================

# Режим отладки (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# Директория для логов
LOG_DIR=/home/ubuntu/video_automation_system/logs

# Максимальное количество результатов YouTube за запрос (1-50)
YOUTUBE_MAX_RESULTS=20

# Количество дней для анализа трендов
YOUTUBE_DAYS_BACK=30

# Минимальное количество просмотров для анализа
YOUTUBE_MIN_VIEWS=10000

# Порог вовлеченности (0.0-1.0)
ENGAGEMENT_THRESHOLD=0.03

# Температура для генерации идей (0.0-1.0)
TEMPERATURE_IDEAS=0.8

# Температура для генерации хуков (0.0-1.0)
TEMPERATURE_HOOKS=0.9

# Температура для генерации сценариев (0.0-1.0)
TEMPERATURE_SCRIPTS=0.7
